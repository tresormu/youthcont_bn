PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/youthcontest
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=<your-strong-random-secret>
JWT_EXPIRES_IN=5d

# Seed Admin (used by: npm run seed:admin)
SEED_ADMIN_NAME=<admin-full-name>
SEED_ADMIN_EMAIL=<admin-email>
SEED_ADMIN_PASSWORD=<strong-password>

# Cloudinary (optional, for file uploads)
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# Staff
STAFF_SEED_PASSWORD=<initial-staff-password>
STAFF_DASHBOARD_URL=http://localhost:5173/staff/login

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email>
SMTP_PASS=<your-app-password>
SMTP_FROM=<your-email>

# Resend (alternative email provider)
RESEND_API_KEY=<resend-api-key>
